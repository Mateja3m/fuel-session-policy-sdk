{
  "name": "@idoa/fuel-session-policy-sdk",
  "version": "0.1.0",
  "description": "Lightweight TypeScript SDK for Fuel session policy flows.",
  "license": "MIT",
  "author": "idoa",
  "private": false,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/Mateja3m/fuel-session-policy-sdk.git",
    "directory": "packages/session-policy-sdk"
  },
  "bugs": {
    "url": "https://github.com/Mateja3m/fuel-session-policy-sdk/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "fuels": ">=0.100.0 <0.110.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "npm run typecheck",
    "test": "vitest run",
    "prepublishOnly": "npm run build && npm run test"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "5.8.2",
    "vitest": "3.2.4"
  }
}
